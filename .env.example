# ----------------------------------------------------------------------
#     Lucy WEB - Example environment variables file
#     Copy this file as .env and fill in the required values
# ----------------------------------------------------------------------

# -------------------- 1. API Configuration --------------------
# Base URL for the Lucy API (e.g., http://localhost:8000/ or https://api.lucy.com)
VITE_API_URL=http://localhost:8000/

# -------------------- 2. Discord Configuration --------------------
# The Client ID of your Discord Application
VITE_DISCORD_BOT_CLIENT_ID=

# Discord permissions bitmask (8 = Administrator)
VITE_DISCORD_BOT_PERMISSIONS=8

# Scopes for the bot invite (comma separated)
VITE_DISCORD_BOT_SCOPES=bot, applications.commands
